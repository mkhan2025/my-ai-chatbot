{
  "manifest_version": 3,
  "name": "Tab Therapist",
  "version": "0.2.0",
  "description": "Sort your tab chaos. Analyze, close, and save sessions.",
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://my-ai-chatbot-3jv4.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Therapist"
  },
  "background": {
    "service_worker": "background.js"
  }
}
